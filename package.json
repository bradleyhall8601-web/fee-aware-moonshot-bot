{
  "name": "fee-aware-moonshot-bot",
  "version": "2.0.0",
  "description": "Production-ready multi-user Solana trading bot with AI monitoring and Telegram integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "health": "tsx src/index.ts health",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "node -e \"console.log('lint: not configured')\"",
    "docker:build": "docker build -t fee-aware-moonshot-bot:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f bot",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop fee-aware-moonshot-bot",
    "pm2:restart": "pm2 restart fee-aware-moonshot-bot",
    "pm2:logs": "pm2 logs",
    "deploy:vps": "git pull origin main && npm install && npm run build && pm2 restart ecosystem.config.js"
  },
  "keywords": [
    "solana",
    "trading",
    "meme",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.7",
    "next": "^16.2.1",
    "openai": "^6.33.0",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "pm2": "^6.0.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "telegraf": "^4.16.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
