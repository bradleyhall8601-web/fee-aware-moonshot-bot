{
  "name": "fee-aware-moonshot-bot",
  "version": "1.0.0",
  "description": "Fee-aware Solana moonshot bot with paper mode default",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests"
  },
  "keywords": ["solana", "trading", "moonshot"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.91.0",
    "@solana/spl-token": "^0.4.8",
    "axios": "^1.7.4",
    "dotenv": "^16.4.5",
    "pino": "^8.20.0",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true
        }
      }]
    }
  }
}