# ──────────────────────────────────────────────
#  fee-aware-moonshot-bot  –  example config
#  Copy to .env and fill in your values.
#  NEVER commit your .env file!
# ──────────────────────────────────────────────

# Solana RPC endpoint (required for live mode; optional for paper mode)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Your wallet private key in base58 or JSON-array format.
# ONLY used when ENABLE_LIVE_TRADING=true.  Keep this secret!
WALLET_PRIVATE_KEY=

# Safety switch — set true only when you are ready to trade real funds.
ENABLE_LIVE_TRADING=false

# Set true to stop all new trades immediately.
ENABLE_KILL_SWITCH=false

# ── API Endpoints ──────────────────────────────
QUOTE_API_BASE=https://api.jup.ag/swap/v1
DEXSCREENER_BASE=https://api.dexscreener.com

# ── Input/Quote token ─────────────────────────
# Default: Wrapped SOL
INPUT_MINT=So11111111111111111111111111111111111111112

# ── Discovery ─────────────────────────────────
# Comma-separated list of token mints to always monitor (optional).
WATCHLIST_MINTS=

# ── Trade sizing ──────────────────────────────
POSITION_SIZE_SOL=0.05
MAX_OPEN_POSITIONS=2

# ── Filters  ──────────────────────────────────
MIN_LIQUIDITY_USD=10000
MAX_PAIR_AGE_HOURS=24
MIN_TXNS=100
MAX_TXNS=1000
MIN_BUYS=100
MAX_BUYS=1000
MIN_SELLS=1
MAX_SELLS=100
MIN_VOLUME_USD=1000
MAX_VOLUME_USD=100000
REQUIRE_5M_PRICE_UP=true

# ── Swap settings ─────────────────────────────
SLIPPAGE_BPS=150
PRIORITY_FEE_MICRO_LAMPORTS=

# ── Exit thresholds ───────────────────────────
STOP_LOSS_PCT=18
TAKE_PROFIT_LOCK_PCT=30
TAKE_PROFIT_LOCK_SELL_PCT=50
RUNNER_TRAIL_STOP_PCT=12
MOMENTUM_EXIT_IF_5M_RED=true

# ── Rate limiting & polling ────────────────────
DEXSCREENER_RATE_LIMIT_RPM=240
POLL_INTERVAL_SECONDS=20

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
