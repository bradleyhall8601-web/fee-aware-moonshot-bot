# ─── SAFETY ────────────────────────────────────────────────────────────────────
# This bot runs in paper/simulation mode only. Live trading is NEVER executed.
ENABLE_LIVE_TRADING=false

# ─── TELEGRAM ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── HELIUS (Solana RPC + enhanced APIs) ───────────────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
HELIUS_API_KEY=

# ─── EXTERNAL APIS ─────────────────────────────────────────────────────────────
DEXSCREENER_BASE_URL=https://api.dexscreener.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
RUGCHECK_BASE_URL=https://api.rugcheck.xyz/v1

# ─── POSTGRES (optional – bot works without it) ────────────────────────────────
POSTGRES_URL=

# ─── PAPER-TRADING CAPITAL ─────────────────────────────────────────────────────
SIM_START_BALANCE_USD=1000
MAX_POSITION_USD=200
MAX_BUY_USD=100

# ─── FILTER THRESHOLDS ─────────────────────────────────────────────────────────
MIN_LIQUIDITY_USD=7500
MIN_VOLUME_USD=500
MIN_BUY_SELL_RATIO=1.05

# ─── EXIT PARAMETERS ───────────────────────────────────────────────────────────
TAKE_PROFIT_PCT=30
TRAILING_STOP_PCT=15

# ─── POLL INTERVAL ─────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=30000

# ─── WALLET MONITORING (comma-separated public addresses, read-only) ───────────
# Add wallets to watch for whale signals. No private keys required or accepted.
WATCH_WALLETS=

# ─── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
