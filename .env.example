# ═══════════════════════════════════════════════════════════════════════════
# FEE-AWARE MOONSHOT BOT - PRODUCTION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Environment
NODE_ENV=production
DEBUG=false
ENABLE_LIVE_TRADING=false

# ── SOLANA BLOCKCHAIN ────────────────────────────────────────────────────────
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
COMMITMENT_LEVEL=confirmed
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ── DATABASE ─────────────────────────────────────────────────────────────────
# SQLite is used by default (see data/bot.db)
# For PostgreSQL, modify src/database.ts

# ── TELEGRAM BOT (MULTI-USER) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Bot token format: 9876543210:ABCDEFGhijklmnopqrstuvwxyz

# ── AI MONITORING AGENT ──────────────────────────────────────────────────────
# Uses Claude Haiku 3.5 for log analysis and auto-fixes
OPENAI_API_KEY=sk-...
OPENAI_MODEL=claude-3-5-sonnet-20241022

# ── TRADING PARAMETERS (USER DEFAULTS) ──────────────────────────────────────
MIN_LIQUIDITY_USDC=10000
MIN_VOLUME_1H=1000
MAX_VOLUME_1H=100000
MAX_FDV_RATIO=250000
MAX_TOKEN_AGE_HOURS=24
MIN_PRICE_CHANGE_5M=0
MIN_TXNS=100
MAX_TXNS=1000
MIN_BUYS=100
MAX_BUYS=1000
MIN_SELLS=1
MAX_SELLS=100
MAX_PRICE_IMPACT_PCT=5
SLIPPAGE_BPS=100
PROFIT_TARGET_PCT=30          # Take profit at 30%
TRAILING_STOP_PCT=15          # Stop loss at -15%
MAX_MOMENTUM_FAIL_COUNT=3

# ── POLLING & MONITORING ────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000         # Check for trades every 5 seconds
MONITOR_INTERVAL_MS=30000     # AI monitoring every 30 seconds
METRICS_INTERVAL_MS=60000     # Metrics collection every 60 seconds

# ── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
LOG_DIR=./logs

# ── VPS DEPLOYMENT ──────────────────────────────────────────────────────────
# These are set automatically by deployment scripts
DEPLOYMENT_ENV=vps
RESTART_ON_CRASH=true
MAX_RESTART_ATTEMPTS=5
